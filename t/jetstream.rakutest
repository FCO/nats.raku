# Consumer ack-sync
{
    my $nats = mocked Nats, overriding => {
        request => -> $subject, $payload {
            is $subject, '$JS.ACK.MY.C', 'ack-sync subject';
            is $payload, '+ACK', 'ack-sync payload';
