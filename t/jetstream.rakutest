{
    my $nats = mocked Nats, overriding => {
        request => -> $subject {
            is $subject, '$JS.API.STREAM.NAMES', 'stream names subject';
        }
    };
    Nats::Stream.new(:nats($nats), name => 'ANY').names;
    check-mock $nats, *.called('request', :once);
