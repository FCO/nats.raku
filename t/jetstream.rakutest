{
    my $nats = mocked Nats, overriding => {
        request => -> $subject {
            is $subject, '$JS.API.STREAM.DELETE.MY', 'stream delete subject';
        }
    };
    Nats::Stream.new(:nats($nats), name => 'MY').delete;
    check-mock $nats, *.called('request', :once);
